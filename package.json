<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Loyalty Admin · All Venues</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Asap+Condensed:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg:#f1ead0;--paper:#fbf7e8;--green:#097d4c;--dark:#053b27;
      --mid:#2a9966;--tan:#e6dcb5;--tan-mid:#c9bd8a;
      --ink:#1a1a17;--ink-mid:#3a3a35;--ink-light:#6b6b62;
    }
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Asap Condensed',sans-serif;background:var(--bg);min-height:100vh;}
    .topbar{background:var(--dark);padding:14px 24px;display:flex;align-items:center;justify-content:space-between;}
    .topbar-logo{font-family:'Anton',sans-serif;font-size:20px;color:#f1ead0;letter-spacing:.02em;}
    .topbar-right{display:flex;align-items:center;gap:12px;}
    .topbar-label{font-size:11px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:rgba(241,234,208,.45);}
    .sms-badge{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:4px 10px;border-radius:100px;}
    .sms-badge.on{background:#2a9966;color:#f1ead0;}
    .sms-badge.off{background:rgba(241,234,208,.15);color:rgba(241,234,208,.4);}
    .venue-tabs{background:#0a2e1a;display:flex;overflow-x:auto;gap:2px;padding:0 24px;}
    .venue-tab{font-family:'Asap Condensed',sans-serif;font-size:13px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:rgba(241,234,208,.5);padding:10px 16px;border:none;background:none;cursor:pointer;border-bottom:3px solid transparent;white-space:nowrap;transition:all .2s;}
    .venue-tab:hover{color:rgba(241,234,208,.8);}
    .venue-tab.active{color:#f1ead0;border-bottom-color:var(--accent-color,#097d4c);}
    .layout{max-width:960px;margin:0 auto;padding:28px 20px 64px;}
    .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:28px;}
    .stat{background:var(--dark);border-radius:10px;padding:16px 20px;}
    .stat-label{font-size:10px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:rgba(241,234,208,.45);margin-bottom:4px;}
    .stat-value{font-family:'Anton',sans-serif;font-size:36px;color:#f1ead0;line-height:1;}
    .section-title{font-family:'Anton',sans-serif;font-size:22px;color:var(--dark);text-transform:uppercase;letter-spacing:.02em;margin-bottom:14px;}
    .add-form{background:var(--paper);border:1px solid var(--tan);border-radius:10px;padding:20px;margin-bottom:28px;display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:12px;align-items:end;}
    .field label{display:block;font-size:10px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--green);margin-bottom:6px;}
    .field input{width:100%;background:var(--bg);border:1px solid var(--tan-mid);border-radius:6px;padding:9px 12px;font-family:'Asap Condensed',sans-serif;font-size:15px;color:var(--ink);outline:none;}
    .field input:focus{border-color:var(--mid);}
    .btn-add{background:var(--green);color:#f1ead0;border:none;border-radius:6px;padding:10px 20px;font-family:'Asap Condensed',sans-serif;font-size:14px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;white-space:nowrap;}
    .btn-add:hover{background:var(--mid);}
    .search-wrap{margin-bottom:16px;}
    .search-wrap input{width:100%;background:var(--paper);border:1px solid var(--tan);border-radius:8px;padding:10px 14px;font-family:'Asap Condensed',sans-serif;font-size:15px;color:var(--ink);outline:none;}
    .search-wrap input:focus{border-color:var(--mid);}
    .table-wrap{background:var(--paper);border:1px solid var(--tan);border-radius:10px;overflow:hidden;}
    table{width:100%;border-collapse:collapse;}
    thead tr{background:var(--dark);}
    th{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:rgba(241,234,208,.55);padding:12px 16px;text-align:left;}
    tbody tr{border-bottom:1px solid var(--tan);transition:background .15s;}
    tbody tr:last-child{border-bottom:none;}
    tbody tr:hover{background:var(--bg);}
    td{padding:12px 16px;font-size:14px;color:var(--ink-mid);}
    td.name{font-size:15px;font-weight:700;color:var(--ink);}
    td.code{font-size:12px;letter-spacing:.1em;color:var(--ink-light);}
    td.phone-cell{font-size:12px;color:var(--ink-light);}
    .btn-link{background:none;border:1px solid var(--green);border-radius:4px;color:var(--green);font-family:'Asap Condensed',sans-serif;font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:4px 10px;cursor:pointer;margin-right:4px;}
    .btn-link:hover{background:var(--green);color:#f1ead0;}
    .btn-sms{background:none;border:1px solid #2a9966;border-radius:4px;color:#2a9966;font-family:'Asap Condensed',sans-serif;font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:4px 10px;cursor:pointer;margin-right:4px;}
    .btn-sms:hover{background:#2a9966;color:#f1ead0;}
    .btn-del{background:none;border:1px solid #e24b4a;border-radius:4px;color:#e24b4a;font-family:'Asap Condensed',sans-serif;font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:4px 10px;cursor:pointer;}
    .btn-del:hover{background:#e24b4a;color:#fff;}
    .empty{padding:40px;text-align:center;font-size:14px;color:var(--ink-light);}
    .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--dark);color:#f1ead0;font-size:13px;font-weight:600;letter-spacing:.06em;padding:10px 20px;border-radius:8px;transition:transform .3s ease;z-index:999;}
    .toast.show{transform:translateX(-50%) translateY(0);}
    .login-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--dark);padding:24px;}
    .login-box{background:var(--paper);border-radius:12px;padding:32px 28px;width:100%;max-width:340px;}
    .login-title{font-family:'Anton',sans-serif;font-size:32px;color:var(--dark);text-transform:uppercase;line-height:.95;margin-bottom:20px;}
    .login-box .field{margin-bottom:14px;}
    .btn-login{width:100%;background:var(--green);color:#f1ead0;border:none;border-radius:6px;padding:12px;font-family:'Asap Condensed',sans-serif;font-size:15px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;margin-top:4px;}
    .btn-login:hover{background:var(--mid);}
    .login-err{color:#e24b4a;font-size:13px;margin-top:10px;}
    @media(max-width:700px){.stats{grid-template-columns:1fr 1fr;}.add-form{grid-template-columns:1fr;}}
  </style>
</head>
<body>
  <div id="root"></div>
  <div class="toast" id="toast"></div>
  <script>
    let authed     = !!sessionStorage.getItem('blv_token');
    let adminToken = sessionStorage.getItem('blv_token') || '';
    let venues     = [];
    let activeVenue= null;
    let members    = [];
    let search     = '';
    let smsEnabled = false;

    function toast(msg) {
      const el = document.getElementById('toast');
      el.textContent = msg;
      el.classList.add('show');
      setTimeout(() => el.classList.remove('show'), 2800);
    }

    const api = {
      async get(path) {
        const r = await fetch(path, { headers: { 'x-admin-token': adminToken } });
        return r.json();
      },
      async post(path, data) {
        const r = await fetch(path, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'x-admin-token': adminToken },
          body: JSON.stringify(data)
        });
        return r.json();
      },
      async del(path) {
        const r = await fetch(path, { method: 'DELETE', headers: { 'x-admin-token': adminToken } });
        return r.json();
      }
    };

    function renderLogin() {
      document.getElementById('root').innerHTML = `
        <div class="login-screen">
          <div class="login-box">
            <div class="login-title">Admin<br>Panel.</div>
            <div class="field"><label>Password</label><input type="password" id="pw" placeholder="Enter admin password" /></div>
            <button class="btn-login" onclick="doLogin()">Sign in</button>
            <div class="login-err" id="login-err"></div>
          </div>
        </div>`;
      document.getElementById('pw').addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });
    }

    async function doLogin() {
      const pw  = document.getElementById('pw').value;
      const res = await api.post('/api/admin/login', { password: pw });
      if (res.ok) {
        adminToken = res.token;
        sessionStorage.setItem('blv_token', adminToken);
        authed = true;
        init();
      } else {
        document.getElementById('login-err').textContent = 'Incorrect password.';
      }
    }

    async function init() {
      if (!authed) { renderLogin(); return; }
      const [vRes, smsRes] = await Promise.all([
        fetch('/api/venues'),
        api.get('/api/admin/sms-enabled')
      ]);
      venues     = await vRes.json();
      smsEnabled = smsRes.enabled || false;
      activeVenue= venues[0];
      await loadMembers();
      render();
    }

    async function loadMembers() {
      members = await api.get(`/api/admin/members/${activeVenue.id}`);
      if (members.error) { sessionStorage.clear(); authed = false; renderLogin(); }
    }

    async function switchVenue(id) {
      activeVenue = venues.find(v => v.id === id);
      search = '';
      await loadMembers();
      render();
    }

    function render() {
      const filtered = members.filter(m =>
        m.name.toLowerCase().includes(search.toLowerCase()) || m.barcode.includes(search)
      );

      const tabs = venues.map(v => `
        <button class="venue-tab ${v.id === activeVenue.id ? 'active' : ''}"
          style="--accent-color:${v.colors.primary}"
          onclick="switchVenue('${v.id}')">${v.name}</button>
      `).join('');

      document.getElementById('root').innerHTML = `
        <div class="topbar">
          <div class="topbar-logo">Loyalty Admin.</div>
          <div class="topbar-right">
            <span class="sms-badge ${smsEnabled ? 'on' : 'off'}">${smsEnabled ? '✓ SMS on' : 'SMS off'}</span>
            <span class="topbar-label">All Venues</span>
          </div>
        </div>
        <div class="venue-tabs">${tabs}</div>
        <div class="layout">
          <div class="stats">
            <div class="stat"><div class="stat-label">Members at ${activeVenue.name}</div><div class="stat-value">${members.length}</div></div>
            <div class="stat"><div class="stat-label">Jug discount</div><div class="stat-value">$1.50</div></div>
            <div class="stat"><div class="stat-label">Pint discount</div><div class="stat-value">50c</div></div>
          </div>

          <div class="section-title">Add member to ${activeVenue.name}</div>
          <div class="add-form">
            <div class="field"><label>Full name</label><input type="text" id="new-name" placeholder="Jamie Dawson" /></div>
            <div class="field"><label>Mobile number ${smsEnabled ? '(sends SMS)' : '(optional)'}</label><input type="tel" id="new-phone" placeholder="021 123 4567" /></div>
            <div class="field"><label>Email (optional)</label><input type="email" id="new-email" placeholder="jamie@email.com" /></div>
            <button class="btn-add" onclick="addMember()">+ Add</button>
          </div>

          <div class="section-title">Members (${filtered.length})</div>
          <div class="search-wrap">
            <input type="text" id="search-input" placeholder="Search by name or barcode…" value="${search}" oninput="onSearch(this.value)" />
          </div>
          <div class="table-wrap">
            <table>
              <thead><tr><th>Name</th><th>Barcode</th><th>Mobile</th><th>Joined</th><th>Actions</th></tr></thead>
              <tbody>
                ${filtered.length === 0
                  ? `<tr><td colspan="5" class="empty">No members yet at ${activeVenue.name}.</td></tr>`
                  : filtered.map(m => `
                    <tr>
                      <td class="name">${m.name}</td>
                      <td class="code">${activeVenue.prefix} · ${m.barcode}</td>
                      <td class="phone-cell">${m.phone || '—'}</td>
                      <td>${m.joined}</td>
                      <td>
                        <button class="btn-link" onclick="copyLink('${m.token}')">Copy link</button>
                        ${smsEnabled && m.phone ? `<button class="btn-sms" onclick="resendSMS('${m.id}','${m.name}')">Resend SMS</button>` : ''}
                        <button class="btn-del" onclick="deleteMember('${m.id}','${m.name}')">Remove</button>
                      </td>
                    </tr>`).join('')}
              </tbody>
            </table>
          </div>
        </div>`;
    }

    function onSearch(val) {
      search = val; render();
      const el = document.getElementById('search-input');
      if (el) { el.focus(); el.setSelectionRange(val.length, val.length); }
    }

    async function addMember() {
      const name  = document.getElementById('new-name').value.trim();
      const phone = document.getElementById('new-phone').value.trim();
      const email = document.getElementById('new-email').value.trim();
      if (!name) { toast('Please enter a name.'); return; }
      const res = await api.post(`/api/admin/members/${activeVenue.id}`, { name, phone, email });
      if (res.member) {
        members.unshift(res.member);
        if (res.smsSent) {
          toast(`${name} added — card link sent by SMS!`);
        } else {
          toast(`${name} added. Link copied!`);
          copyLink(res.member.token, false);
        }
        render();
      }
    }

    async function resendSMS(id, name) {
      const parts   = activeVenue.id;
      const res     = await api.post(`/api/admin/resend-sms/${activeVenue.id}/${id}`, {});
      if (res.ok) { toast(`SMS resent to ${name}.`); }
      else { toast(`SMS failed: ${res.error || 'unknown error'}`); }
    }

    async function deleteMember(id, name) {
      if (!confirm(`Remove ${name} from ${activeVenue.name}?`)) return;
      await api.del(`/api/admin/members/${activeVenue.id}/${id}`);
      members = members.filter(m => m.id !== id);
      toast(`${name} removed.`);
      render();
    }

    function copyLink(token, showToast = true) {
      const url = `${window.location.origin}/card.html?t=${token}`;
      navigator.clipboard.writeText(url).then(() => {
        if (showToast) toast('Card link copied to clipboard.');
      });
    }

    init();
  </script>
</body>
</html>
